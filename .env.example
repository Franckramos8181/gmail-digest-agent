# Gmail OAuth (Google Cloud Console -> OAuth 2.0 Desktop client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set after running: python -m src.auth_gmail
GMAIL_REFRESH_TOKEN=

# Kimi / Moonshot (https://platform.moonshot.cn/)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# Slack: incoming webhook (simplest) OR bot token + channel
SLACK_WEBHOOK_URL=
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C0123456789

# Job behavior
MAX_EMAILS=50
LOOKBACK_HOURS=48
TIMEZONE=America/New_York
INCLUDE_WEEKENDS=true

# Optional: persist processed message IDs to avoid duplicate digests
CHECKPOINT_PATH=.checkpoint.json
